+        pr_err("aic8800: %s: vif or rwnx_hw NULL\n", __func__);
+        dev_kfree_skb(skb);
+        return NETDEV_TX_OK;
+    }
+
 #ifdef CONFIG_ONE_TXQ
     skb->queue_mapping = rwnx_select_txq(rwnx_vif, skb);
 #endif
